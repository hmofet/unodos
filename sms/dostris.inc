; ============================================================================
; UnoDOS/SMS — Dostris (falling-blocks game), the M3 game showcase.
; Included by kernel.asm. Board is BW x BH cells inside the Dostris window;
; each board byte holds the tile to draw (0 = empty). Pieces come from the
; Contract-shaped piece tables generated by mkdata (piece_masks/piece_tiles).
; The window owns the d-pad while it is topmost (see main_loop): left/right
; move, up or trigger-1 rotate, down soft-drops, trigger-2 closes.
; ============================================================================

set_dirty:
    ld a, 1
    ld (v_dirty), a
    ret

; ---- topmost_proc: -> A = WPROC of the topmost window, or $FF if none ------
topmost_proc:
    ld a, (v_zcount)
    or a
    jr z, tp_none
    dec a
    ld l, a
    ld h, 0
    ld de, zlist
    add hl, de
    ld a, (hl)
    call win_ptr
    ld a, (ix+WPROC)
    ret
tp_none:
    ld a, $FF
    ret

; ---- dostris_window_open: -> A = 1 if a visible Dostris window exists ------
dostris_window_open:
    xor a
    ld (g_tmp), a
dwo_loop:
    ld a, (g_tmp)
    cp MAXWIN
    jr nc, dwo_no
    call win_ptr
    ld a, (ix+WSTATE)
    or a
    jr z, dwo_next
    ld a, (ix+WPROC)
    cp 7
    jr z, dwo_yes
dwo_next:
    ld a, (g_tmp)
    inc a
    ld (g_tmp), a
    jr dwo_loop
dwo_yes:
    ld a, 1
    ret
dwo_no:
    xor a
    ret

; ---- rng / mod7 ------------------------------------------------------------
rng:
    ld a, (g_seed)
    ld b, a
    add a, a
    add a, a
    add a, b                        ; *5
    inc a
    ld (g_seed), a
    ret
mod7:
    cp 7
    ret c
    sub 7
    jr mod7

; ---- get_mask: DE = piece mask for (g_type, g_rot) -------------------------
get_mask:
    ld a, (g_type)
    add a, a
    add a, a                        ; type*4
    ld e, a
    ld a, (g_rot)
    add a, e                        ; type*4 + rot
    add a, a                        ; *2 (word)
    ld e, a
    ld d, 0
    ld hl, piece_masks
    add hl, de
    ld e, (hl)
    inc hl
    ld d, (hl)                      ; DE = mask (LE)
    ret

; ---- piece_collide: B=trial px, C=trial py -> A=1 collide / 0 free ---------
; px is unsigned but negatives wrap mod 256; since BW=10 << 246, a single
; `cp BW` upper-bound test catches both out-of-board and (wrapped) negatives.
piece_collide:
    ld a, b
    ld (g_tx), a
    ld a, c
    ld (g_ty), a
    call get_mask                   ; DE = mask
    ld b, 0                         ; bit index 0..15
pc_loop:
    bit 7, d                        ; mask bit15 = this cell present?
    jr z, pc_next
    push de
    ld a, b
    and 3
    ld c, a
    ld a, (g_tx)
    add a, c                        ; bx
    cp BW
    jr nc, pc_hitpop                ; bx out of [0,BW)
    ld c, a                         ; bx
    ld a, b
    and $0C
    rrca
    rrca                            ; row = b>>2
    ld e, a
    ld a, (g_ty)
    add a, e                        ; by
    cp BH
    jr nc, pc_hitpop                ; by >= BH (floor)
    ; board index = by*BW + bx
    ld l, a
    ld h, 0
    add hl, hl
    ld d, h
    ld e, l
    add hl, hl
    add hl, hl
    add hl, de                      ; by*10
    ld e, c
    ld d, 0
    add hl, de                      ; + bx
    ld de, g_board
    add hl, de
    ld a, (hl)
    or a
    jr nz, pc_hitpop                ; cell occupied
    pop de
    jr pc_next
pc_hitpop:
    pop de
    ld a, 1
    ret
pc_next:
    sla e
    rl d                            ; shift mask left -> next cell into bit15
    inc b
    ld a, b
    cp 16
    jr nz, pc_loop
    xor a
    ret

; ---- moves -----------------------------------------------------------------
ds_left:
    ld a, (g_px)
    dec a
    ld (g_tmp), a
    ld b, a
    ld a, (g_py)
    ld c, a
    call piece_collide
    or a
    ret nz
    ld a, (g_tmp)
    ld (g_px), a
    jp set_dirty
ds_right:
    ld a, (g_px)
    inc a
    ld (g_tmp), a
    ld b, a
    ld a, (g_py)
    ld c, a
    call piece_collide
    or a
    ret nz
    ld a, (g_tmp)
    ld (g_px), a
    jp set_dirty
ds_rotate:
    ld a, (g_rot)
    ld (g_savedrot), a
    inc a
    and 3
    ld (g_rot), a
    ld a, (g_px)
    ld b, a
    ld a, (g_py)
    ld c, a
    call piece_collide
    or a
    jr z, dr_ok
    ld a, (g_savedrot)
    ld (g_rot), a                   ; blocked: revert
    ret
dr_ok:
    jp set_dirty
; soft drop moves the piece down one cell; it does NOT lock (gravity locks a
; rested piece on its next tick) — so holding down never cascades pieces.
ds_softdrop:
    ld a, (g_px)
    ld b, a
    ld a, (g_py)
    inc a
    ld c, a
    call piece_collide
    or a
    ret nz                          ; blocked: rest (gravity will lock it)
    ld a, (g_py)
    inc a
    ld (g_py), a
    jp set_dirty

; ---- dostris_input: consume pad edges while the game is focused -----------
dostris_input:
    ld a, (v_pad_edge)
    bit 5, a                        ; trigger 2 -> close
    jr z, di_moves
    jp close_topmost
di_moves:
    ld a, (g_state)
    or a
    ret nz                          ; game over: ignore movement
    ld a, (v_pad_edge)
    bit 2, a
    call nz, ds_left
    ld a, (v_pad_edge)
    bit 3, a
    call nz, ds_right
    ld a, (v_pad_edge)
    bit 0, a                        ; up = rotate
    call nz, ds_rotate
    ld a, (v_pad_edge)
    bit 4, a                        ; trigger 1 = rotate
    call nz, ds_rotate
    ld a, (v_pad)
    bit 1, a                        ; down held = soft drop
    call nz, ds_softdrop
    ret

; ---- dostris_gravity: one step every FALLRATE frames ----------------------
dostris_gravity:
    ld a, (v_gpause)                ; AUTOTEST freezes gravity once the script ends
    or a
    ret nz
    ld a, (g_state)
    or a
    ret nz
    call dostris_window_open
    or a
    ret z
    ld a, (g_fall)
    inc a
    ld (g_fall), a
    cp FALLRATE
    ret c
    xor a
    ld (g_fall), a
    ld a, (g_px)
    ld b, a
    ld a, (g_py)
    inc a
    ld c, a
    call piece_collide
    or a
    jr nz, dg_lock
    ld a, (g_py)
    inc a
    ld (g_py), a
    jp set_dirty
dg_lock:
    call dostris_lock
    call dostris_clearlines
    call dostris_spawn
    jp set_dirty

; ---- dostris_lock: stamp the current piece into the board -----------------
dostris_lock:
    ld a, (g_type)
    ld l, a
    ld h, 0
    ld de, piece_tiles
    add hl, de
    ld a, (hl)
    ld (g_locktile), a
    ld a, (g_px)
    ld (g_tx), a
    ld a, (g_py)
    ld (g_ty), a
    call get_mask
    ld b, 0
dl_loop:
    bit 7, d
    jr z, dl_next
    push de
    ld a, b
    and 3
    ld c, a
    ld a, (g_tx)
    add a, c
    ld c, a                         ; bx
    ld a, b
    and $0C
    rrca
    rrca
    ld e, a
    ld a, (g_ty)
    add a, e                        ; by
    ld l, a
    ld h, 0
    add hl, hl
    ld d, h
    ld e, l
    add hl, hl
    add hl, hl
    add hl, de                      ; by*10
    ld e, c
    ld d, 0
    add hl, de                      ; + bx
    ld de, g_board
    add hl, de
    ld a, (g_locktile)
    ld (hl), a
    pop de
dl_next:
    sla e
    rl d
    inc b
    ld a, b
    cp 16
    jr nz, dl_loop
    ret

; ---- dostris_spawn: pick a new piece at the top -> game over if blocked ----
dostris_spawn:
    call rng
    call mod7
    ld (g_type), a
    xor a
    ld (g_rot), a
    ld (g_fall), a
    ld a, 3
    ld (g_px), a
    xor a
    ld (g_py), a
    ld a, (g_px)
    ld b, a
    ld a, (g_py)
    ld c, a
    call piece_collide
    or a
    ret z
    ld a, 1
    ld (g_state), a                 ; spawn blocked -> game over
    ret

; ---- dostris_init: fresh board + first piece ------------------------------
dostris_init:
    ld hl, g_board
    ld de, g_board+1
    ld bc, BW*BH-1
    ld (hl), 0
    ldir
    xor a
    ld (g_lines), a
    ld (g_state), a
    ld (g_fall), a
    ld a, (v_ticks)
    or 1
    ld (g_seed), a
    ld a, (v_ticks+1)
    ld (g_seed+1), a
    call dostris_spawn
    ret

; ---- line clearing ---------------------------------------------------------
dostris_clearlines:
    ld a, BH-1
    ld (g_row), a
cl_loop:
    ld a, (g_row)
    cp 255                          ; dec'd below 0 -> done
    ret z
    call row_full
    or a
    jr z, cl_dec
    call collapse_row
    ld a, (g_lines)
    inc a
    ld (g_lines), a
    jr cl_loop                      ; recheck the same row (row above fell in)
cl_dec:
    ld a, (g_row)
    dec a
    ld (g_row), a
    jr cl_loop

; row_ptr: A=row -> HL = g_board + row*BW
row_ptr:
    ld l, a
    ld h, 0
    add hl, hl
    ld d, h
    ld e, l
    add hl, hl
    add hl, hl
    add hl, de
    ld de, g_board
    add hl, de
    ret

; row_full: -> A=1 if row (g_row) is completely filled
row_full:
    ld a, (g_row)
    call row_ptr
    ld b, BW
rf_loop:
    ld a, (hl)
    or a
    jr z, rf_no
    inc hl
    djnz rf_loop
    ld a, 1
    ret
rf_no:
    xor a
    ret

; collapse_row: drop every row above (g_row) down by one, clear row 0
collapse_row:
    ld a, (g_row)
    ld (g_tmp), a
cr_loop:
    ld a, (g_tmp)
    or a
    jr z, cr_top
    ld a, (g_tmp)
    call row_ptr
    push hl                         ; dst = row r
    ld a, (g_tmp)
    dec a
    call row_ptr                    ; src = row r-1
    pop de                          ; de = dst
    ld bc, BW
    ldir
    ld a, (g_tmp)
    dec a
    ld (g_tmp), a
    jr cr_loop
cr_top:
    ld hl, g_board
    ld b, BW
cr_clr:
    ld (hl), 0
    inc hl
    djnz cr_clr
    ret

; ---- rendering -------------------------------------------------------------
; dostris_draw: board cells + live piece + score panel + game-over banner.
; ix = the Dostris window entry.
dostris_draw:
    xor a
    ld (g_row), a
dd_row:
    ld a, (g_row)
    cp BH
    jp nc, dd_after
    ld a, (ix+WX)
    inc a
    ld b, a                         ; col = WX+1
    ld a, (ix+WY)
    inc a
    ld c, a
    ld a, (g_row)
    add a, c
    ld c, a                         ; row = WY+1+g_row
    call cell_addr
    call vram_set_addr
    ld a, (g_row)
    call row_ptr                    ; hl -> board row start
    ld b, BW
dd_cell:
    ld a, (hl)
    out (VDP_DATA), a
    xor a
    out (VDP_DATA), a
    inc hl
    djnz dd_cell
    ld a, (g_row)
    inc a
    ld (g_row), a
    jr dd_row
dd_after:
    ld a, (g_state)
    or a
    jr nz, dd_score
    call dostris_draw_piece
dd_score:
    call dostris_draw_score
    ld a, (g_state)
    or a
    ret z
    ld a, 6
    ld hl, s_gameover
    call cput
    ret

; draw_block: A=tile, D=board col, E=board row (ix=window)
draw_block:
    ld (g_locktile), a
    ld a, (ix+WX)
    inc a
    add a, d
    ld b, a
    ld a, (ix+WY)
    inc a
    add a, e
    ld c, a
    call cell_addr
    call vram_set_addr
    ld a, (g_locktile)
    out (VDP_DATA), a
    xor a
    out (VDP_DATA), a
    ret

dostris_draw_piece:
    ld a, (g_type)
    ld l, a
    ld h, 0
    ld de, piece_tiles
    add hl, de
    ld a, (hl)
    ld (g_pietile), a
    call get_mask
    ld b, 0
ddp_loop:
    bit 7, d
    jr z, ddp_next
    push de
    push bc
    ld a, b
    and 3
    ld c, a
    ld a, (g_px)
    add a, c
    ld d, a                         ; board col
    ld a, b
    and $0C
    rrca
    rrca
    ld c, a
    ld a, (g_py)
    add a, c
    ld e, a                         ; board row
    ld a, (g_pietile)
    call draw_block
    pop bc
    pop de
ddp_next:
    sla e
    rl d
    inc b
    ld a, b
    cp 16
    jr nz, ddp_loop
    ret

dostris_draw_score:
    ld a, (ix+WX)
    add a, 12
    ld d, a
    ld a, (ix+WY)
    inc a
    ld e, a
    ld hl, s_lines
    ld c, T_FONT
    call puts_at
    ld a, (g_lines)
    ld hl, g_numstr
    call put2
    xor a
    ld (hl), a
    ld a, (ix+WX)
    add a, 12
    ld d, a
    ld a, (ix+WY)
    add a, 2
    ld e, a
    ld hl, g_numstr
    ld c, T_FONT
    call puts_at
    ret

s_lines:    db "Lines",0
s_gameover: db "GAME OVER",0

; ---- AUTOTEST: drop a handful of pieces to show the game in play ----------
  IFDEF AUTOTEST_DOSTRIS
; Spread pieces left-to-right across the board so it reads as an in-play stack
; with a live piece falling, rather than a centre tower. Each L/R must toggle
; back to 0 to register as a fresh edge.
; Per piece: nudge horizontally (down released), slam to the bottom with PAD_D,
; then idle ~28 frames so GRAVITY locks the rested piece and spawns the next.
; (Soft drop no longer locks, so a slam never cascades.) After the script,
; ai_hold freezes gravity, leaving the last piece mid-air for the capture.
auto_script:
    db 2,208, 86, 0
    db 2,208, 86, B1               ; click the Dostris icon -> launch
    db 4,208, 86, 0
    ; piece 1 -> hard left
    db 2,0,0, PAD_L
    db 2,0,0, 0
    db 2,0,0, PAD_L
    db 2,0,0, 0
    db 2,0,0, PAD_L
    db 2,0,0, 0
    db 2,0,0, PAD_L
    db 2,0,0, 0
    db 14,0,0, PAD_D
    db 28,0,0, 0                   ; gravity locks + spawns
    ; piece 2 -> left of centre
    db 2,0,0, PAD_L
    db 2,0,0, 0
    db 2,0,0, PAD_L
    db 2,0,0, 0
    db 14,0,0, PAD_D
    db 28,0,0, 0
    ; piece 3 -> centre, rotated
    db 1,0,0, B1
    db 2,0,0, 0
    db 14,0,0, PAD_D
    db 28,0,0, 0
    ; piece 4 -> right of centre
    db 2,0,0, PAD_R
    db 2,0,0, 0
    db 2,0,0, PAD_R
    db 2,0,0, 0
    db 14,0,0, PAD_D
    db 28,0,0, 0
    ; piece 5 -> hard right
    db 2,0,0, PAD_R
    db 2,0,0, 0
    db 2,0,0, PAD_R
    db 2,0,0, 0
    db 2,0,0, PAD_R
    db 2,0,0, 0
    db 14,0,0, PAD_D
    db 28,0,0, 0
    ; piece 6 -> spawns centre; nudge + drop a little, leave it FALLING
    db 2,0,0, PAD_L
    db 2,0,0, 0
    db 4,0,0, PAD_D
    db 2,0,0, 0
    db 0,0,0,0                     ; end -> gravity frozen, piece hangs mid-air
  ENDIF
