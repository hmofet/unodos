#!/bin/bash
# UnoDosFlasherCapture.app main executable.
# Runs in the user's login (aqua) session with this bundle's TCC identity, so
# once the bundle has Screen Recording permission it can screenshot the flasher
# headlessly. Downloads the latest macOS flasher, opens it, captures its window,
# quits it, and cleans up. It never clicks Install, so no drive is written.
set -u
HERE="$(cd "$(dirname "$0")" && pwd)"          # .../Contents/MacOS
OUT="$HOME/unodos-flasher-shots"
mkdir -p "$OUT"
LOG="$OUT/capture.log"
URL="https://github.com/hmofet/unodos/releases/latest/download/UnoDosFlasher-macOS.zip"

{
  echo "=== $(date -Iseconds) capture start ==="
  D="$(mktemp -d /tmp/unoflash.XXXXXX)"
  curl -sL -o "$D/f.zip" "$URL" || { echo "download failed"; exit 1; }
  echo "downloaded $(stat -f%z "$D/f.zip" 2>/dev/null) bytes"
  unzip -q "$D/f.zip" -d "$D"
  APP="$(ls -d "$D"/*.app 2>/dev/null | head -1)"
  [ -n "$APP" ] || { echo "no .app in zip"; exit 1; }

  open "$APP"

  WID=-1
  for i in $(seq 1 24); do
    WID="$("$HERE/winid" 2>/dev/null)"
    [ "$WID" != "-1" ] && [ -n "$WID" ] && break
    sleep 0.5
  done
  echo "window id: $WID"
  sleep 1                                        # let the drive scan settle

  if [ "$WID" != "-1" ] && [ -n "$WID" ]; then
    screencapture -x -o -l"$WID" -t png "$OUT/flasher-macos.png"
    echo "screencapture rc=$? -> $OUT/flasher-macos.png"
  else
    echo "flasher window not found"
  fi

  osascript -e 'tell application "UnoDosFlasher" to quit' 2>/dev/null || pkill -f 'UnoDosFlasher' 2>/dev/null
  rm -rf "$D"                                     # do not keep the download
  echo "=== done ==="
} >> "$LOG" 2>&1
